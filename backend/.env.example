APP_NAME=ReviewsApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite  # optional; defaults to database/database.sqlite

# For MySQL instead, use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=reviewsapp
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5500,127.0.0.1,127.0.0.1:5500

# Hugging Face
HUGGINGFACE_API_TOKEN=your_token_here
HUGGINGFACE_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment
